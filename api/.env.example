# Copy to api/.env on the webserver and fill in real values.
# api/.env is ignored by git and blocked by api/.htaccess.

DB_HOST=localhost
DB_NAME=meistercarports_leads
DB_USER=meistercarports_user
DB_PASS=CHANGE_ME
DB_CHARSET=utf8mb4

LEADTABLE_WEBHOOK_URL=https://api.lead-table.com/api/webhook/generic/PASTE_FULL_TOKEN_HERE

# Generate: php -r "echo bin2hex(random_bytes(32)), PHP_EOL;"
RATE_LIMIT_SALT=CHANGE_ME_RANDOM_64_HEX_CHARS
RATE_LIMIT_WINDOW_SECONDS=3600
RATE_LIMIT_MAX_REQUESTS=10

RETRY_MAX_ATTEMPTS=30
RETRY_BATCH_SIZE=20

# Google Ads server-side/offline conversion upload.
# Conversion is queued only after successful LeadTable delivery.
GOOGLE_ADS_CONVERSIONS_ENABLED=false
GOOGLE_ADS_API_VERSION=v23
GOOGLE_ADS_CUSTOMER_ID=4921325707
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
GOOGLE_ADS_CONVERSION_ACTION_ID=7568021279
GOOGLE_ADS_CONVERSION_VALUE=400
GOOGLE_ADS_CONVERSION_CURRENCY=EUR
GOOGLE_ADS_CONVERSION_MAX_ATTEMPTS=20
GOOGLE_ADS_CONVERSION_BATCH_SIZE=10
GOOGLE_ADS_TIMEOUT_SECONDS=20
# Upload mode: datamanager is preferred for stable service-account auth; google_ads is the legacy OAuth refresh-token path.
GOOGLE_ADS_CONVERSION_UPLOAD_MODE=datamanager

# Legacy Google Ads API OAuth mode only.
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=

# Google Data Manager API service-account mode.
GOOGLE_DATAMANAGER_ENABLED=true
GOOGLE_DATAMANAGER_VALIDATE_ONLY=true
# Preferred: base64 of the full service-account JSON key file (single line).
GOOGLE_DATAMANAGER_SERVICE_ACCOUNT_JSON_BASE64=
# Alternative: set email + private key manually instead of JSON_BASE64.
GOOGLE_DATAMANAGER_SERVICE_ACCOUNT_EMAIL=service-account@example-project.iam.gserviceaccount.com
GOOGLE_DATAMANAGER_PRIVATE_KEY=
GOOGLE_DATAMANAGER_DESTINATION_REFERENCE=mp_lead

# Only needed if retry-leads.php is called via URL instead of CLI cron.
# Generate: php -r "echo bin2hex(random_bytes(24)), PHP_EOL;"
CRON_TOKEN=CHANGE_ME_FOR_URL_CRON
